def _last_user_message_content(messages: list) -> str:
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            return str(msg.content)
        if getattr(msg, "type", None) == "human":
            return str(getattr(msg, "content", ""))
    return ""


def _llm_trace_payload(response: Any) -> dict[str, Any]:
    payload = {"content": str(getattr(response, "content", ""))}
    tool_calls = getattr(response, "tool_calls", None)
    if tool_calls:
        payload["tool_calls"] = [
            {
                "id": call.get("id"),
                "name": call.get("name"),
                "args": call.get("args", {}),
            }
            for call in tool_calls
        ]
    return payload


def _emit_human_review_event(
    event: str,
    node_id: str,
    trigger: str,
    *,
    tool_name: str | None = None,
    message: str | None = None,
) -> None:
    payload = {"event": event, "node": node_id, "trigger": trigger}
    if tool_name is not None:
        payload["tool"] = tool_name
    if message:
        payload["message"] = message
    print(json.dumps(payload, sort_keys=True), file=sys.stderr)


def _human_review_allowed(node_id: str, trigger: str) -> bool:
    mode = os.environ.get("ABP_HITL_MODE", "deny").strip().lower()
    if mode == "allow":
        return True
    specific_key = f"ABP_APPROVE_HITL_{node_id.upper()}_{trigger.upper()}"
    specific_value = os.environ.get(specific_key, "").strip().lower()
    if specific_value in {"1", "true", "yes", "allow", "approved"}:
        return True
    approvals = {
        item.strip()
        for item in os.environ.get("ABP_APPROVED_HITL", "").split(",")
        if item.strip()
    }
    return f"{node_id}:{trigger}" in approvals


def _should_request_human_review(
    hitl: Any,
    trigger: str,
    *,
    tool_name: str | None = None,
) -> bool:
    if hitl is None or not hitl.get("enabled", False):
        return False
    configured_trigger = hitl["trigger"]
    if configured_trigger not in {trigger, "always"}:
        return False
    if tool_name is not None and hitl["tools"] and tool_name not in hitl["tools"]:
        return False
    return True


def _require_human_review(
    node_id: str,
    hitl: Any,
    trigger: str,
    *,
    tool_name: str | None = None,
) -> None:
    if not _should_request_human_review(hitl, trigger, tool_name=tool_name):
        return
    review_message = hitl.get("message") or "Human review required"
    _emit_human_review_event(
        "human_review_requested",
        node_id,
        trigger,
        tool_name=tool_name,
        message=review_message,
    )
    if _human_review_allowed(node_id, trigger):
        _emit_human_review_event(
            "human_review_granted",
            node_id,
            trigger,
            tool_name=tool_name,
            message=review_message,
        )
        return
    raise PermissionError(
        f"Human review required for node '{node_id}' at trigger '{trigger}'. "
        "Set ABP_HITL_MODE=allow or explicitly approve this node/trigger via "
        "ABP_APPROVED_HITL or ABP_APPROVE_HITL_<NODE>_<TRIGGER>."
    )

{% for node in ir.nodes %}
{% if node.agent %}
def node_{{ node.id | safe_id }}(state: AgentState) -> dict:
    """{{ node.description }}"""
{% if node.agent.human_in_the_loop %}
    hitl = {
        "enabled": {{ node.agent.human_in_the_loop.enabled | to_python }},
        "trigger": "{{ node.agent.human_in_the_loop.trigger.value }}",
        "tools": {{ node.agent.human_in_the_loop.tools | to_python }},
        "message": {{ node.agent.human_in_the_loop.message | to_python }},
    }
{% else %}
    hitl = None
{% endif %}
    set_current_node("{{ node.id }}")
    emit_trace_event("node_started", node="{{ node.id }}", input_state=state)
    {% set temperature = node.agent.temperature if node.agent.temperature is not none else ir.settings.default_temperature %}
    {{ make_llm(node, temperature) }}
{% if node.tool_defs %}
    tools = TOOLS.get("{{ node.id }}", [])
    tool_map = {t.name: t for t in tools}
    if tools:
        llm = llm.bind_tools(tools)
{% endif %}
    # Working copy — system prompt prepended once, tool messages appended inline
    working: list = list(state.get("messages", []))
{% if node.agent.system_prompt %}
    system_prompt = """{{ node.agent.system_prompt | escape_string }}"""
    if not any(isinstance(m, SystemMessage) for m in working):
        working = [SystemMessage(content=system_prompt)] + working
{% endif %}
{% if node.agent.rag and node.agent.rag.enabled and node.agent.rag.mode.value != "tool_only" %}
    rag_query = _last_user_message_content(working)
    if rag_query:
        try:
            rag_context = str(TOOLS_BY_NAME["{{ node.agent.rag.retrieval_tool }}"].invoke({"query": rag_query}))
        except Exception as exc:
            rag_context = f"Retrieval error: {exc}"
{% if node.agent.rag.max_context_chars is not none %}
        rag_context = rag_context[:{{ node.agent.rag.max_context_chars }}]
{% endif %}
        rag_message = SystemMessage(
            content="""{{ node.agent.rag.context_prompt | escape_string }}""" + "\n\n" + rag_context
        )
        if working and isinstance(working[0], SystemMessage):
            working = [working[0], rag_message] + working[1:]
        else:
            working = [rag_message] + working
{% endif %}
    new_messages: list = []
    updates: dict = {}
{% if node.tool_defs %}
    # ReAct loop: invoke LLM, execute any tool calls, repeat until plain response
    while True:
        response = llm.invoke(working)
        record_llm_output("{{ node.id }}", _llm_trace_payload(response))
        working.append(response)
        new_messages.append(response)
        if not getattr(response, "tool_calls", None):
            _require_human_review("{{ node.id }}", hitl, "before_response")
            break
        for tc in response.tool_calls:
            fn = tool_map.get(tc["name"])
            if fn is None:
                content = f"Unknown tool: {tc['name']}"
            else:
                try:
                    _require_human_review("{{ node.id }}", hitl, "before_tool_call", tool_name=tc["name"])
                    content = str(fn.invoke(tc.get("args", {})))
                    _require_human_review("{{ node.id }}", hitl, "after_tool_call", tool_name=tc["name"])
                except PermissionError:
                    raise
                except Exception as exc:
                    content = f"Tool error: {exc}"
            tool_msg = ToolMessage(content=content, tool_call_id=tc["id"])
            working.append(tool_msg)
            new_messages.append(tool_msg)
{% else %}
    response = llm.invoke(working)
    record_llm_output("{{ node.id }}", _llm_trace_payload(response))
    _require_human_review("{{ node.id }}", hitl, "before_response")
    new_messages.append(response)
{% endif %}
    updates["messages"] = new_messages
{% for field_name, field_def in node.agent.output_schema.items() %}
    # Extract {{ field_name }} from last structured tool call
    for msg in reversed(new_messages):
        if hasattr(msg, "tool_calls"):
            for tc in msg.tool_calls:
                if "{{ field_name }}" in tc.get("args", {}):
                    updates["{{ field_name }}"] = tc["args"]["{{ field_name }}"]
                    break
{% endfor %}
    emit_trace_event("node_finished", node="{{ node.id }}", input_state=state, output_state=updates)
    clear_current_node()
    return updates

