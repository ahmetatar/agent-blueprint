def _approval_env_var_name(tool_name: str) -> str:
    normalized = "".join(ch if ch.isalnum() else "_" for ch in tool_name.upper())
    return f"ABP_APPROVE_TOOL_{normalized}"


def _approved_tools() -> set[str]:
    raw = os.environ.get("ABP_APPROVED_TOOLS", "")
    return {item.strip() for item in raw.split(",") if item.strip()}


def _emit_approval_event(event: str, tool_name: str, args: dict[str, Any]) -> None:
    payload = {"event": event, "tool": tool_name, "args": args}
    emit_trace_event(event, tool=tool_name, args=args, metadata={"source": "tool_approval"})
    print(json.dumps(payload, sort_keys=True), file=sys.stderr)


def _is_tool_approved(tool_name: str) -> bool:
    mode = os.environ.get("ABP_TOOL_APPROVAL_MODE", "deny").strip().lower()
    if mode == "allow":
        return True
    if tool_name in _approved_tools():
        return True
    decision = os.environ.get(_approval_env_var_name(tool_name), "").strip().lower()
    return decision in {"1", "true", "yes", "allow", "approved"}


def _require_approval(tool_name: str, args: dict[str, Any]) -> None:
    _emit_approval_event("approval_requested", tool_name, args)
    if _is_tool_approved(tool_name):
        _emit_approval_event("approval_granted", tool_name, args)
        return
    raise PermissionError(
        f"Approval required for tool '{tool_name}'. "
        "Set ABP_TOOL_APPROVAL_MODE=allow or explicitly approve the tool via "
        "ABP_APPROVED_TOOLS or a tool-specific ABP_APPROVE_TOOL_* env var."
    )


def _maybe_stub_tool(tool_name: str, args: dict[str, Any]) -> Any:
    if tool_mode() in {"stub", "replay"}:
        return consume_tool_output(tool_name, args)
    return None

