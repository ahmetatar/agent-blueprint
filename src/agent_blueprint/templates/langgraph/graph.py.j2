"""Graph definition generated from blueprint: {{ ir.name }}"""
# Generated by agent-blueprint {{ ir.version }}

from langgraph.graph import StateGraph, END
from langgraph.checkpoint.memory import MemorySaver

from .state import AgentState
from .nodes import (
{% for node in ir.nodes %}
    node_{{ node.id | safe_id }},
{% endfor %}
)


def build_graph():
    builder = StateGraph(AgentState)

    # Register nodes
{% for node in ir.nodes %}
    builder.add_node("{{ node.id }}", node_{{ node.id | safe_id }})
{% endfor %}

    # Set entry point
    builder.set_entry_point("{{ ir.entry_point }}")

    # Add edges
{% for edge in ir.edges %}
{% if edge.is_conditional %}
    def _route_{{ edge.from_node | safe_id }}(state: AgentState) -> str:
{% for target in edge.targets %}
{% if target.condition %}
        if {{ target.condition.to_dict_access('state') }}:
            return "{{ target.target }}"
{% endif %}
{% endfor %}
{% for target in edge.targets %}
{% if target.is_default and not target.condition %}
        return "{{ target.target }}"
{% endif %}
{% endfor %}

    builder.add_conditional_edges(
        "{{ edge.from_node }}",
        _route_{{ edge.from_node | safe_id }},
        {
{% for target in edge.targets %}
            "{{ target.target }}": {% if target.target == "END" %}END{% else %}"{{ target.target }}"{% endif %},
{% endfor %}
        }
    )
{% else %}
{% for target in edge.targets %}
    builder.add_edge("{{ edge.from_node }}", {% if target.target == "END" %}END{% else %}"{{ target.target }}"{% endif %})
{% endfor %}
{% endif %}
{% endfor %}

    # Memory / checkpointing
{% if ir.memory.backend.value == "in_memory" %}
    memory = MemorySaver()
    return builder.compile(checkpointer=memory)
{% else %}
    # TODO: Configure {{ ir.memory.backend.value }} checkpointer
    # connection_string = os.environ.get("{{ ir.memory.connection_string_env or 'MEMORY_DB_URL' }}")
    memory = MemorySaver()
    return builder.compile(checkpointer=memory)
{% endif %}


graph = build_graph()
