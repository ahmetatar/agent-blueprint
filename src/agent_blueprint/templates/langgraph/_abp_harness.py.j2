"""ABP harness fixture helpers for: {{ ir.name }}"""
# Generated by agent-blueprint {{ ir.version }}

from __future__ import annotations

import json
import os
from typing import Any

from _abp_trace import record_tool_output


_HARNESS_FIXTURES_CACHE: dict[str, Any] | None = None
_TOOL_CURSOR: dict[str, int] = {}
_LLM_CURSOR: dict[str, int] = {}


def _harness_mode(env_name: str, default: str) -> str:
    return os.environ.get(env_name, default).strip().lower()


def llm_mode() -> str:
    return _harness_mode("ABP_LLM_MODE", "live")


def tool_mode() -> str:
    return _harness_mode("ABP_TOOL_MODE", "live")


def harness_fixtures() -> dict[str, Any]:
    global _HARNESS_FIXTURES_CACHE
    if _HARNESS_FIXTURES_CACHE is not None:
        return _HARNESS_FIXTURES_CACHE
    raw = os.environ.get("ABP_HARNESS_FIXTURES", "").strip()
    if not raw:
        _HARNESS_FIXTURES_CACHE = {"llm_outputs": {}, "tool_outputs": {}}
        return _HARNESS_FIXTURES_CACHE
    try:
        parsed = json.loads(raw)
    except json.JSONDecodeError as exc:
        raise RuntimeError("Invalid ABP_HARNESS_FIXTURES JSON payload") from exc
    if not isinstance(parsed, dict):
        raise RuntimeError("ABP_HARNESS_FIXTURES must decode to an object")
    _HARNESS_FIXTURES_CACHE = {
        "llm_outputs": parsed.get("llm_outputs") or {},
        "tool_outputs": parsed.get("tool_outputs") or {},
    }
    return _HARNESS_FIXTURES_CACHE


def _next_fixture(sequence: list[Any], cursor_map: dict[str, int], key: str, label: str) -> Any:
    index = cursor_map.get(key, 0)
    if index >= len(sequence):
        raise RuntimeError(f"No remaining {label} fixtures for '{key}'")
    cursor_map[key] = index + 1
    return sequence[index]


def _materialize_fixture(entry: Any, *, key: str, kind: str) -> Any:
    if isinstance(entry, dict):
        if "error" in entry:
            raise RuntimeError(str(entry["error"]))
        if "result" in entry:
            return entry["result"]
    return entry


def consume_tool_output(tool_name: str, args: dict[str, Any]) -> Any:
    del args
    fixtures = harness_fixtures()["tool_outputs"]
    if tool_mode() not in {"stub", "replay"}:
        return None
    if tool_name not in fixtures:
        raise RuntimeError(
            f"No stubbed tool fixture configured for '{tool_name}' while ABP_TOOL_MODE={tool_mode()}"
        )
    entry = fixtures[tool_name]
    if isinstance(entry, list):
        entry = _next_fixture(entry, _TOOL_CURSOR, tool_name, "tool")
    record_tool_output(tool_name, entry)
    return _materialize_fixture(entry, key=tool_name, kind="tool")


class MockLLMResponse:
    def __init__(self, *, content: str = "", tool_calls: list[dict[str, Any]] | None = None) -> None:
        self.content = content
        self.tool_calls = tool_calls or []


class HarnessMockLLM:
    def __init__(self, node_id: str) -> None:
        self._node_id = node_id
        self._tools = []

    def bind_tools(self, tools: list[Any]) -> "HarnessMockLLM":
        self._tools = tools
        return self

    def invoke(self, working: list[Any]) -> MockLLMResponse:
        del working
        entry = _next_fixture(
            harness_fixtures()["llm_outputs"].get(self._node_id, []),
            _LLM_CURSOR,
            self._node_id,
            "LLM",
        )
        if isinstance(entry, str):
            return MockLLMResponse(content=entry)
        if not isinstance(entry, dict):
            return MockLLMResponse(content=str(entry))
        tool_calls = []
        for index, raw_call in enumerate(entry.get("tool_calls", []) or []):
            tool_calls.append({
                "id": raw_call.get("id", f"{self._node_id}-tool-{index}"),
                "name": raw_call["name"],
                "args": raw_call.get("args", {}),
            })
        return MockLLMResponse(
            content=str(entry.get("content", "")),
            tool_calls=tool_calls,
        )


def build_llm(node_id: str, factory: Any) -> Any:
    if llm_mode() in {"mock", "replay"}:
        if node_id not in harness_fixtures()["llm_outputs"]:
            raise RuntimeError(
                f"No mocked LLM fixture configured for node '{node_id}' while ABP_LLM_MODE={llm_mode()}"
            )
        return HarnessMockLLM(node_id)
    return factory()
