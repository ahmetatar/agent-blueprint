def _last_user_message_content(messages: list) -> str:
    for msg in reversed(messages):
        if isinstance(msg, HumanMessage):
            return str(msg.content)
        if getattr(msg, "type", None) == "human":
            return str(getattr(msg, "content", ""))
    return ""


def _llm_trace_payload(response: Any) -> dict[str, Any]:
    payload = {"content": str(getattr(response, "content", ""))}
    tool_calls = getattr(response, "tool_calls", None)
    if tool_calls:
        payload["tool_calls"] = [
            {
                "id": call.get("id"),
                "name": call.get("name"),
                "args": call.get("args", {}),
            }
            for call in tool_calls
        ]
    return payload


def _emit_human_review_event(
    event: str,
    node_id: str,
    trigger: str,
    *,
    tool_name: str | None = None,
    message: str | None = None,
) -> None:
    payload = {"event": event, "node": node_id, "trigger": trigger}
    if tool_name is not None:
        payload["tool"] = tool_name
    if message:
        payload["message"] = message
    print(json.dumps(payload, sort_keys=True), file=sys.stderr)


def _contract_error(
    node_id: str,
    message: str,
    *,
    state: Any | None = None,
    updates: Any | None = None,
    stage: str,
    contract_kind: str,
) -> None:
    emit_trace_event(
        "contract_failed",
        node=node_id,
        input_state=state,
        output_state=updates,
        error=message,
        metadata={"stage": stage, "contract_kind": contract_kind},
    )
    clear_current_node()
    raise ValueError(message)


def _require_state_fields(node_id: str, state: AgentState, field_names: list[str]) -> None:
    missing = [
        field_name
        for field_name in field_names
        if field_name not in state or state.get(field_name) is None
    ]
    if missing:
        quoted = ", ".join(repr(field_name) for field_name in missing)
        _contract_error(
            node_id,
            f"Node contract error: node '{node_id}' requires state field(s) {quoted} before execution",
            state=state,
            stage="node_precondition",
            contract_kind="requires",
        )


def _require_produced_fields(node_id: str, state: AgentState, updates: dict[str, Any], field_names: list[str]) -> None:
    missing = [field_name for field_name in field_names if field_name not in updates]
    if missing:
        quoted = ", ".join(repr(field_name) for field_name in missing)
        _contract_error(
            node_id,
            f"Node contract error: node '{node_id}' did not produce required field(s) {quoted}",
            state=state,
            updates=updates,
            stage="node_postcondition",
            contract_kind="produces",
        )


def _ensure_fields_not_mutated(
    node_id: str,
    state: AgentState,
    updates: dict[str, Any],
    field_names: list[str],
    *,
    contract_kind: str,
) -> None:
    mutated = [
        field_name
        for field_name in field_names
        if field_name in updates and updates[field_name] != state.get(field_name)
    ]
    if mutated:
        quoted = ", ".join(repr(field_name) for field_name in mutated)
        if contract_kind == "immutable_fields":
            message = (
                f"State contract error: node '{node_id}' attempted to mutate immutable field(s) {quoted}"
            )
        else:
            message = (
                f"Node contract error: node '{node_id}' attempted to mutate forbidden field(s) {quoted}"
            )
        _contract_error(
            node_id,
            message,
            state=state,
            updates=updates,
            stage="node_postcondition",
            contract_kind=contract_kind,
        )


def _validate_schema_value(path: str, value: Any, schema: dict[str, Any]) -> Any:
    if value is None:
        if schema.get("nullable", False):
            return None
        raise ValueError(f"{path} cannot be null")

    expected_type = str(schema.get("type", "")).lower()

    if expected_type in {"string", "str"}:
        if not isinstance(value, str):
            raise ValueError(f"{path} must be of type '{schema['type']}'")
        validated = value
    elif expected_type in {"integer", "int"}:
        if not (isinstance(value, int) and not isinstance(value, bool)):
            raise ValueError(f"{path} must be of type '{schema['type']}'")
        validated = value
    elif expected_type in {"number", "float"}:
        if not ((isinstance(value, int) or isinstance(value, float)) and not isinstance(value, bool)):
            raise ValueError(f"{path} must be of type '{schema['type']}'")
        validated = value
    elif expected_type in {"boolean", "bool"}:
        if not isinstance(value, bool):
            raise ValueError(f"{path} must be of type '{schema['type']}'")
        validated = value
    elif expected_type in {"list", "array"}:
        if not isinstance(value, list):
            raise ValueError(f"{path} must be of type '{schema['type']}'")
        item_schema = schema.get("items")
        if item_schema:
            validated = [
                _validate_schema_value(f"{path}[{index}]", item, item_schema)
                for index, item in enumerate(value)
            ]
        else:
            validated = value
    elif expected_type in {"object", "dict"}:
        if not isinstance(value, dict):
            raise ValueError(f"{path} must be of type '{schema['type']}'")
        properties = schema.get("properties", {})
        required_fields = schema.get("required", [])
        additional = schema.get("additionalProperties", schema.get("additional_properties", None))
        validated = {}

        for field_name in required_fields:
            if field_name not in value:
                raise ValueError(f"{path}.{field_name} is required")

        for field_name, field_schema in properties.items():
            if field_name in value:
                validated[field_name] = _validate_schema_value(
                    f"{path}.{field_name}",
                    value[field_name],
                    field_schema,
                )
            elif "default" in field_schema and field_schema.get("default") is not None:
                validated[field_name] = field_schema["default"]

        extra_fields = sorted(set(value.keys()) - set(properties.keys()))
        if additional is False and extra_fields:
            rendered = ", ".join(extra_fields)
            raise ValueError(f"{path} has unknown field(s): {rendered}")

        if additional is True or additional is None:
            for field_name in extra_fields:
                validated[field_name] = value[field_name]
        elif isinstance(additional, dict):
            for field_name in extra_fields:
                validated[field_name] = _validate_schema_value(
                    f"{path}.{field_name}",
                    value[field_name],
                    additional,
                )
        return validated
    else:
        validated = value

    allowed_values = schema.get("enum")
    if allowed_values is not None and validated not in allowed_values:
        raise ValueError(f"{path} must be one of {allowed_values}")

    return validated


def _extract_structured_output_candidate(new_messages: list[Any]) -> Any:
    for msg in reversed(new_messages):
        tool_calls = getattr(msg, "tool_calls", None)
        if tool_calls:
            for tc in reversed(tool_calls):
                args = tc.get("args", {})
                if args:
                    return args
        content = getattr(msg, "content", None)
        if isinstance(content, str) and content.strip():
            try:
                return json.loads(content)
            except json.JSONDecodeError:
                continue
    return None


def _validate_node_output_contract(
    node_id: str,
    state: AgentState,
    new_messages: list[Any],
    schema: dict[str, Any],
    *,
    contract_kind: str,
    required: bool,
) -> Any:
    candidate = _extract_structured_output_candidate(new_messages)
    if candidate is None:
        if required:
            _contract_error(
                node_id,
                f"Node output contract error: node '{node_id}' did not produce structured output",
                state=state,
                updates={"messages": new_messages},
                stage="node_output_contract",
                contract_kind=contract_kind,
            )
        return None
    try:
        return _validate_schema_value(f"node '{node_id}' output", candidate, schema)
    except ValueError as exc:
        _contract_error(
            node_id,
            f"Node output contract error: {exc}",
            state=state,
            updates={"messages": new_messages},
            stage="node_output_contract",
            contract_kind=contract_kind,
        )


def _human_review_allowed(node_id: str, trigger: str) -> bool:
    mode = os.environ.get("ABP_HITL_MODE", "deny").strip().lower()
    if mode == "allow":
        return True
    specific_key = f"ABP_APPROVE_HITL_{node_id.upper()}_{trigger.upper()}"
    specific_value = os.environ.get(specific_key, "").strip().lower()
    if specific_value in {"1", "true", "yes", "allow", "approved"}:
        return True
    approvals = {
        item.strip()
        for item in os.environ.get("ABP_APPROVED_HITL", "").split(",")
        if item.strip()
    }
    return f"{node_id}:{trigger}" in approvals


def _should_request_human_review(
    hitl: Any,
    trigger: str,
    *,
    tool_name: str | None = None,
) -> bool:
    if hitl is None or not hitl.get("enabled", False):
        return False
    configured_trigger = hitl["trigger"]
    if configured_trigger not in {trigger, "always"}:
        return False
    if tool_name is not None and hitl["tools"] and tool_name not in hitl["tools"]:
        return False
    return True


def _require_human_review(
    node_id: str,
    hitl: Any,
    trigger: str,
    *,
    tool_name: str | None = None,
) -> None:
    if not _should_request_human_review(hitl, trigger, tool_name=tool_name):
        return
    review_message = hitl.get("message") or "Human review required"
    _emit_human_review_event(
        "human_review_requested",
        node_id,
        trigger,
        tool_name=tool_name,
        message=review_message,
    )
    if _human_review_allowed(node_id, trigger):
        _emit_human_review_event(
            "human_review_granted",
            node_id,
            trigger,
            tool_name=tool_name,
            message=review_message,
        )
        return
    raise PermissionError(
        f"Human review required for node '{node_id}' at trigger '{trigger}'. "
        "Set ABP_HITL_MODE=allow or explicitly approve this node/trigger via "
        "ABP_APPROVED_HITL or ABP_APPROVE_HITL_<NODE>_<TRIGGER>."
    )

{% for node in ir.nodes %}
{% if node.agent %}
def node_{{ node.id | safe_id }}(state: AgentState) -> dict:
    """{{ node.description }}"""
{% if node.agent.human_in_the_loop %}
    hitl = {
        "enabled": {{ node.agent.human_in_the_loop.enabled | to_python }},
        "trigger": "{{ node.agent.human_in_the_loop.trigger.value }}",
        "tools": {{ node.agent.human_in_the_loop.tools | to_python }},
        "message": {{ node.agent.human_in_the_loop.message | to_python }},
    }
{% else %}
    hitl = None
{% endif %}
    set_current_node("{{ node.id }}")
    emit_trace_event("node_started", node="{{ node.id }}", input_state=state)
{% if node.contract and node.contract.requires %}
    _require_state_fields("{{ node.id }}", state, {{ node.contract.requires | to_python }})
{% endif %}
    {% set temperature = node.agent.temperature if node.agent.temperature is not none else ir.settings.default_temperature %}
    {{ make_llm(node, temperature) }}
{% if node.tool_defs %}
    tools = TOOLS.get("{{ node.id }}", [])
    tool_map = {t.name: t for t in tools}
    if tools:
        llm = llm.bind_tools(tools)
{% endif %}
    # Working copy — system prompt prepended once, tool messages appended inline
    working: list = list(state.get("messages", []))
{% if node.agent.system_prompt %}
    system_prompt = """{{ node.agent.system_prompt | escape_string }}"""
    if not any(isinstance(m, SystemMessage) for m in working):
        working = [SystemMessage(content=system_prompt)] + working
{% endif %}
{% if node.agent.rag and node.agent.rag.enabled and node.agent.rag.mode.value != "tool_only" %}
    rag_query = _last_user_message_content(working)
    if rag_query:
        try:
            rag_context = str(TOOLS_BY_NAME["{{ node.agent.rag.retrieval_tool }}"].invoke({"query": rag_query}))
        except Exception as exc:
            rag_context = f"Retrieval error: {exc}"
{% if node.agent.rag.max_context_chars is not none %}
        rag_context = rag_context[:{{ node.agent.rag.max_context_chars }}]
{% endif %}
        rag_message = SystemMessage(
            content="""{{ node.agent.rag.context_prompt | escape_string }}""" + "\n\n" + rag_context
        )
        if working and isinstance(working[0], SystemMessage):
            working = [working[0], rag_message] + working[1:]
        else:
            working = [rag_message] + working
{% endif %}
    new_messages: list = []
    updates: dict = {}
{% if node.tool_defs %}
    # ReAct loop: invoke LLM, execute any tool calls, repeat until plain response
    while True:
        response = llm.invoke(working)
        record_llm_output("{{ node.id }}", _llm_trace_payload(response))
        working.append(response)
        new_messages.append(response)
        if not getattr(response, "tool_calls", None):
            _require_human_review("{{ node.id }}", hitl, "before_response")
            break
        for tc in response.tool_calls:
            fn = tool_map.get(tc["name"])
            if fn is None:
                content = f"Unknown tool: {tc['name']}"
            else:
                try:
                    _require_human_review("{{ node.id }}", hitl, "before_tool_call", tool_name=tc["name"])
                    content = str(fn.invoke(tc.get("args", {})))
                    _require_human_review("{{ node.id }}", hitl, "after_tool_call", tool_name=tc["name"])
                except PermissionError:
                    raise
                except Exception as exc:
                    content = f"Tool error: {exc}"
            tool_msg = ToolMessage(content=content, tool_call_id=tc["id"])
            working.append(tool_msg)
            new_messages.append(tool_msg)
{% else %}
    response = llm.invoke(working)
    record_llm_output("{{ node.id }}", _llm_trace_payload(response))
    _require_human_review("{{ node.id }}", hitl, "before_response")
    new_messages.append(response)
{% endif %}
    updates["messages"] = new_messages
{% if node.contract and node.contract.output_contract and ir.contracts %}
    validated_output = _validate_node_output_contract(
        "{{ node.id }}",
        state,
        new_messages,
        {{ ir.contracts.outputs[node.contract.output_contract].model_dump(by_alias=True) | to_python }},
        contract_kind="output_contract",
        required=True,
    )
    if isinstance(validated_output, dict):
        updates.update(validated_output)
{% if node.contract.produces and node.contract.produces | length == 1 %}
    elif validated_output is not None:
        updates["{{ node.contract.produces[0] }}"] = validated_output
{% endif %}
{% endif %}
{% if ir.contracts and ir.contracts.state.immutable_fields %}
    _ensure_fields_not_mutated(
        "{{ node.id }}",
        state,
        updates,
        {{ ir.contracts.state.immutable_fields | to_python }},
        contract_kind="immutable_fields",
    )
{% endif %}
{% if node.contract and node.contract.forbids_mutation %}
    _ensure_fields_not_mutated(
        "{{ node.id }}",
        state,
        updates,
        {{ node.contract.forbids_mutation | to_python }},
        contract_kind="forbids_mutation",
    )
{% endif %}
{% if node.contract and node.contract.produces %}
    _require_produced_fields("{{ node.id }}", state, updates, {{ node.contract.produces | to_python }})
{% endif %}
    emit_trace_event("node_finished", node="{{ node.id }}", input_state=state, output_state=updates)
    clear_current_node()
    return updates

