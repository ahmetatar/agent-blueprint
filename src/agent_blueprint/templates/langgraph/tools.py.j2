def _format_retrieval_item(item: Any) -> str:
    if isinstance(item, str):
        return item
    if isinstance(item, dict):
        content = item.get("content") or item.get("page_content") or item.get("text") or ""
        metadata = item.get("metadata") or {}
        source = item.get("source") or metadata.get("source")
        score = item.get("score")
    else:
        content = getattr(item, "page_content", None) or getattr(item, "content", None) or str(item)
        metadata = getattr(item, "metadata", {}) or {}
        source = metadata.get("source")
        score = getattr(item, "score", None)
    suffix_parts = []
    if source:
        suffix_parts.append(f"source={source}")
    if score is not None:
        suffix_parts.append(f"score={score}")
    suffix = f"\n[{', '.join(suffix_parts)}]" if suffix_parts else ""
    return f"{content}{suffix}"


def _format_retrieval_result(result: Any) -> str:
    if isinstance(result, str):
        return result
    if isinstance(result, dict) and "chunks" in result:
        result = result["chunks"]
    if isinstance(result, (list, tuple)):
        return "\n\n".join(_format_retrieval_item(item) for item in result)
    return _format_retrieval_item(result)


